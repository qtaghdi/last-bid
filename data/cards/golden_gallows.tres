[resource]
script = ExtResource("1_def")
id = &"golden_gallows"
actual_name = "황금 교수대"
description = "다음 심판에 가장 부유한 참가자 전원 체력 2 피해. 발동 후 제거."
public_name = "금빛 처형 장치"
category = &"judgment"
risk_tier = &"high"
risk_range = "높음"
value_tier = &"situational"
value_range = "상황 의존"
trigger_timing = "다음 심판"
target_type = "자산 기준"
tags = PackedStringArray("judgment", "high_risk", "rich", "lethal", "disaster", "high_reward", "gamble")
public_clues = Array[ExtResource("3_clue")]([SubResource("Clue_role"), SubResource("Clue_risk"), SubResource("Clue_value"), SubResource("Clue_timing"), SubResource("Clue_target")])
hidden_clues = Array[ExtResource("3_clue")]([SubResource("Clue_hidden_rich"), SubResource("Clue_hidden_many"), SubResource("Clue_hidden_consume")])
starting_bid = 300
effects = Array[ExtResource("2_effect")]([SubResource("Effect_judgment")])
seal_reveal_texts = PackedStringArray("가장 부유한 참가자를 노린다", "다음 심판에 강한 피해를 주고 사라진다", "다음 심판에 부자 전원 체력 2 피해 후 소비")
seal_accident_effect = SubResource("Effect_accident")
effects_while_sealed = true
transfer_policy = 0
burn_cost = 150
burn_effects = Array[ExtResource("2_effect")]([SubResource("Effect_burn")])
