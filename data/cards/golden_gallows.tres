display_text = "다음 심판"
related_tags = PackedStringArray("judgment", "delayed")
estimated_reward = 410
estimated_risk_cost = 270

[sub_resource type="Resource" id="Clue_target"]
script = ExtResource("3_clue")
clue_id = &"gallows_target"
