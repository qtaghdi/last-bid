[gd_resource type="Resource" script_class="CardDefinition" load_steps=14 format=3]

[ext_resource type="Script" path="res://scripts/cards/card_definition.gd" id="1_def"]
[ext_resource type="Script" path="res://scripts/cards/card_effect_definition.gd" id="2_effect"]
[ext_resource type="Script" path="res://scripts/cards/card_clue_definition.gd" id="3_clue"]

[sub_resource type="Resource" id="Effect_judgment"]
script = ExtResource("2_effect")
trigger = 1
effect_type = 0
target_selector = 4
amount = -2
consume_after_trigger = true
description = "다음 JUDGMENT에 가장 부유한 참가자 전원 체력 2 피해"

[sub_resource type="Resource" id="Effect_accident"]
script = ExtResource("2_effect")
trigger = 4
effect_type = 0
target_selector = 3
amount = -1
description = "봉인이 끊어져 소유자 체력 1 피해"

[sub_resource type="Resource" id="Effect_burn"]
script = ExtResource("2_effect")
trigger = 7
effect_type = 0
target_selector = 4
amount = -1
description = "소각 반동으로 가장 부유한 참가자 전원 체력 1 피해"

[sub_resource type="Resource" id="Clue_role"]
script = ExtResource("3_clue")
clue_id = &"gallows_role"
clue_type = &"role"
display_text = "심판"
related_tags = PackedStringArray("judgment", "disaster")
estimated_reward = 360
estimated_risk_cost = 230

[sub_resource type="Resource" id="Clue_risk"]
script = ExtResource("3_clue")
clue_id = &"gallows_risk"
clue_type = &"risk"
display_text = "높음"
related_tags = PackedStringArray("high_risk", "lethal", "disaster")
estimated_reward = 420
estimated_risk_cost = 320

[sub_resource type="Resource" id="Clue_value"]
script = ExtResource("3_clue")
clue_id = &"gallows_value"
clue_type = &"value"
display_text = "상황 의존"
related_tags = PackedStringArray("high_reward", "gamble")
estimated_reward = 500
estimated_risk_cost = 250

[sub_resource type="Resource" id="Clue_timing"]
script = ExtResource("3_clue")
clue_id = &"gallows_timing"
