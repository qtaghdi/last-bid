[resource]
script = ExtResource("1_def")
id = &"broken_chalice"
actual_name = "깨진 성배"
description = "소유자가 다음 치명 피해를 받을 때 1회 무효. 발동 후 제거."
public_name = "금이 간 의식용 잔"
category = &"ownership"
risk_tier = &"medium"
risk_range = "낮음~중간"
value_tier = &"medium"
value_range = "중간"
trigger_timing = "조건부"
target_type = "소유자"
tags = PackedStringArray("ownership", "defense", "lethal_prevention", "cursed", "rare", "unique")
public_clues = Array[ExtResource("3_clue")]([SubResource("Clue_role"), SubResource("Clue_risk"), SubResource("Clue_value"), SubResource("Clue_timing"), SubResource("Clue_target")])
hidden_clues = Array[ExtResource("3_clue")]([SubResource("Clue_hidden_guard"), SubResource("Clue_hidden_consume"), SubResource("Clue_hidden_uncertain")])
starting_bid = 250
effects = Array[ExtResource("2_effect")]([SubResource("Effect_guard")])
