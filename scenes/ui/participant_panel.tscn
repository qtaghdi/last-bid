[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/participant_panel.gd" id="1"]

[node name="ParticipantPanel" type="PanelContainer"]
custom_minimum_size = Vector2(252, 0)
script = ExtResource("1")

[node name="Column" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Header" type="HBoxContainer" parent="Column"]
layout_mode = 2

[node name="Title" type="Label" parent="Column/Header"]
layout_mode = 2
size_flags_horizontal = 3
theme_type_variation = &"GoldLabel"
theme_override_font_sizes/font_size = 14
text = "PARTICIPANTS"

[node name="DetailHint" type="Label" parent="Column/Header"]
layout_mode = 2
theme_type_variation = &"MutedLabel"
theme_override_font_sizes/font_size = 12
text = "+ 세부"

[node name="ParticipantScroll" type="ScrollContainer" parent="Column"]
layout_mode = 2
size_flags_vertical = 3
theme_type_variation = &"ScrollList"
horizontal_scroll_mode = 0

[node name="ParticipantList" type="VBoxContainer" parent="Column/ParticipantScroll"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 6
