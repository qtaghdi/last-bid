[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/auction_panel.gd" id="1"]

[node name="AuctionPanel" type="PanelContainer"]
custom_minimum_size = Vector2(430, 175)
script = ExtResource("1")

[node name="Column" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 8

[node name="Title" type="Label" parent="Column"]
layout_mode = 2
theme_type_variation = &"GoldLabel"
text = "AUCTION STATUS"

[node name="PriceLabel" type="Label" parent="Column"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"BrightGoldLabel"
theme_override_font_sizes/font_size = 27
text = "현재가  입찰 없음"

[node name="DetailLabel" type="Label" parent="Column"]
unique_name_in_owner = true
layout_mode = 2
text = "경매 정보"
autowrap_mode = 2

[node name="GuidanceLabel" type="Label" parent="Column"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"MutedLabel"
text = "행동 안내"
autowrap_mode = 2
