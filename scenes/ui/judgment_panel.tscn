[gd_scene load_steps=2 format=3]

[ext_resource type="Script" path="res://scripts/ui/judgment_panel.gd" id="1"]

[node name="JudgmentPanel" type="PanelContainer"]
custom_minimum_size = Vector2(450, 400)
theme_type_variation = &"ElevatedPanel"
script = ExtResource("1")

[node name="Column" type="VBoxContainer" parent="."]
layout_mode = 2
theme_override_constants/separation = 12

[node name="Eyebrow" type="Label" parent="Column"]
layout_mode = 2
theme_type_variation = &"GoldLabel"
text = "RESOLUTION"

[node name="TitleLabel" type="Label" parent="Column"]
unique_name_in_owner = true
layout_mode = 2
theme_override_font_sizes/font_size = 26
text = "심판 결과"

[node name="Divider" type="HSeparator" parent="Column"]
layout_mode = 2

[node name="ResultScroll" type="ScrollContainer" parent="Column"]
custom_minimum_size = Vector2(410, 250)
layout_mode = 2
size_flags_vertical = 3
theme_type_variation = &"ScrollList"
horizontal_scroll_mode = 0

[node name="ResultList" type="VBoxContainer" parent="Column/ResultScroll"]
unique_name_in_owner = true
layout_mode = 2
size_flags_horizontal = 3
theme_override_constants/separation = 6

[node name="SummaryLabel" type="RichTextLabel" parent="Column"]
unique_name_in_owner = true
visible = false
layout_mode = 2
bbcode_enabled = true
text = "결과 없음"

[node name="FooterLabel" type="Label" parent="Column"]
unique_name_in_owner = true
layout_mode = 2
theme_type_variation = &"MutedLabel"
text = "생존자"
autowrap_mode = 2
